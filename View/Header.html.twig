{# Fixed site header – edit this single file to update the header on all pages #}
<script>
(function() {
    document.querySelectorAll("link[rel*='icon'], link[rel='apple-touch-icon']").forEach(function(el) {
        el.parentNode.removeChild(el);
    });
    [
        { rel: 'apple-touch-icon', href: 'https://yevea.com/001-vectores/favicon-180x180.png', sizes: '180x180' },
        { rel: 'icon', href: 'https://yevea.com/001-vectores/favicon-32x32.png', sizes: '32x32', type: 'image/png' },
        { rel: 'icon', href: 'https://yevea.com/001-vectores/favicon-16x16.png', sizes: '16x16', type: 'image/png' },
        { rel: 'icon', href: 'https://yevea.com/001-vectores/favicon.ico' }
    ].forEach(function(f) {
        var link = document.createElement('link');
        link.rel = f.rel;
        link.href = f.href;
        if (f.sizes) link.setAttribute('sizes', f.sizes);
        if (f.type) link.type = f.type;
        document.head.appendChild(link);
    });
})();
</script>
{# Schema.org Organization: consolidates "Yevea" as a single entity for search
   engines and AI agents. sameAs profiles are configured in Admin → YeveaStore. #}
<script type="application/ld+json">
{
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "Yevea",
    "url": "https://yevea.com/",
    "logo": "https://yevea.com/001-vectores/logo-yevea-white.svg",
    "description": "{{ fsc.t('sawmill-desc') | e('js') }}"{% if fsc.socialProfiles is defined and fsc.socialProfiles() is not empty %},
    "sameAs": [
        {% for profileUrl in fsc.socialProfiles() %}"{{ profileUrl }}"{% if not loop.last %},{% endif %}
        {% endfor %}
    ]{% endif %}
}
</script>

<header id="yeveastore-header">
    <div class="container d-flex align-items-center justify-content-between">
        <a href="/"><img style="width:100px;height:25px;" src="https://yevea.com/001-vectores/logo-yevea-white.svg" alt="madera olivo - logo"><sup>®</sup></a>
        <div class="d-flex align-items-center gap-2">
            {# Language switcher dropdown #}
            {% if fsc.availableLanguages is defined %}
            <div class="dropdown">
                <button class="btn btn-sm dropdown-toggle lang-switcher-btn" type="button"
                        id="lang-switcher" data-bs-toggle="dropdown" aria-expanded="false">
                    {{ fsc.currentLangLabel }}
                </button>
                <ul class="dropdown-menu dropdown-menu-end" aria-labelledby="lang-switcher">
                    {% for code, label in fsc.availableLanguages %}
                    <li>
                        <a class="dropdown-item {% if code == fsc.currentLang %}active{% endif %}"
                           href="{{ fsc.langSwitchUrl(code) }}">
                            {{ label }}
                        </a>
                    </li>
                    {% endfor %}
                </ul>
            </div>
            {% endif %}
            <button type="button" id="hamburger-toggle" class="hamburger-toggle" aria-label="Toggle menu" aria-expanded="false">&#9776;</button>
        </div>
    </div>
    <div id="hamburger-menu" class="hamburger-dropdown">
        <ul>
            <li><a href="#placeholder-home">{{ fsc.t('nav-home') }}</a></li>

        {% if fsc.categories is defined and fsc.categories is not empty %}
            <li><a href="{{ asset('Productos') }}">{{ fsc.t('all') }}</a></li>
            {% for cat in fsc.categories %}
            <li><a href="{{ asset('Productos') }}?category={{ cat.codfamilia }}">{{ fsc.categoryNames[cat.codfamilia] | default(cat.descripcion) }}</a></li>
            {% endfor %}
        {% endif %}

            <li><a href="#placeholder-products">{{ fsc.t('products') }}</a></li>
            <li><a href="#placeholder-about">{{ fsc.t('nav-about') }}</a></li>
            <li><a href="#placeholder-contact">{{ fsc.t('nav-contact') }}</a></li>
            <li><a href="#placeholder-faq">{{ fsc.t('nav-faq') }}</a></li>
        </ul>
    </div>
</header>

<script>
document.getElementById('hamburger-toggle').addEventListener('click', function () {
    // Close the language dropdown if it is open
    var langBtn = document.getElementById('lang-switcher');
    if (langBtn) {
        var bsDropdown = bootstrap.Dropdown.getInstance(langBtn);
        if (bsDropdown) {
            bsDropdown.hide();
        }
    }
    this.classList.toggle('open');
    document.getElementById('hamburger-menu').classList.toggle('show');
    this.setAttribute('aria-expanded', this.classList.contains('open'));
});

// When the language dropdown opens, close the hamburger menu
var langSwitcher = document.getElementById('lang-switcher');
if (langSwitcher) {
    langSwitcher.addEventListener('show.bs.dropdown', function () {
        var toggle = document.getElementById('hamburger-toggle');
        var menu = document.getElementById('hamburger-menu');
        toggle.classList.remove('open');
        menu.classList.remove('show');
        toggle.setAttribute('aria-expanded', 'false');
    });
}

// Close hamburger menu when clicking outside of it
document.addEventListener('click', function (e) {
    var toggle = document.getElementById('hamburger-toggle');
    var menu = document.getElementById('hamburger-menu');
    if (!toggle.contains(e.target) && !menu.contains(e.target)) {
        toggle.classList.remove('open');
        menu.classList.remove('show');
        toggle.setAttribute('aria-expanded', 'false');
    }
});
</script>
