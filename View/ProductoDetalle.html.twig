{% extends "Master/MenuTemplate.html.twig" %}

{% block meta %}
    <meta http-equiv="Content-Type" content="text/html; charset=UTF-8"/>
    {% if fsc.product is not null %}
    <title>{{ fsc.product.name }} | Yevea</title>
    <meta name="description" content="{{ fsc.product.description | striptags | slice(0, 155) }}"/>
    <meta name="robots" content="index, follow"/>
    <link rel="canonical" href="{{ fsc.baseUrl() }}/producto?url={{ fsc.product.slug }}"/>
    {% else %}
    <title>{{ fsc.t('product-not-found') }} | Yevea</title>
    <meta name="robots" content="noindex"/>
    {% endif %}
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <meta name="generator" content="FacturaScripts"/>
{% endblock %}

{% block navbar %}{% endblock %}

{% block body %}
{% include 'Header.html.twig' %}
{% include 'Hreflang.html.twig' %}
<div class="container mt-4">

    {% if fsc.product is not null %}
    {# Schema.org structured data for AI agents and search engines #}
    <script type="application/ld+json">
    {
        "@context": "https://schema.org",
        "@type": "Product",
        "name": "{% if fsc.defaultVariant and fsc.defaultVariant.description is not empty %}{{ fsc.product.name | e('js') }} – {{ fsc.defaultVariant.description | e('js') }}{% else %}{{ fsc.product.name | e('js') }}{% endif %}",
        "description": "{{ fsc.product.description | e('js') }}",
        "sku": "{{ fsc.product.referencia }}",
        "material": "{{ fsc.t('olive-wood') }}",
        {% if fsc.currentLang is defined %}"inLanguage": "{{ fsc.currentLang[:2] }}",{% endif %}
        "url": "{{ asset('producto') }}?url={{ fsc.product.slug }}",
        {% if fsc.productImages is not empty %}"image": "{{ fsc.productImages[0].url }}",{% endif %}
        {% if fsc.product.peso %}"weight": {"@type": "QuantitativeValue", "value": {{ fsc.product.peso }}, "unitCode": "KGM"},{% endif %}
        {% if fsc.product.largo %}"depth": {"@type": "QuantitativeValue", "value": {{ fsc.product.largo }}, "unitCode": "CMT"},{% endif %}
        {% if fsc.product.ancho %}"width": {"@type": "QuantitativeValue", "value": {{ fsc.product.ancho }}, "unitCode": "CMT"},{% endif %}
        {% if fsc.product.espesor %}"height": {"@type": "QuantitativeValue", "value": {{ fsc.product.espesor }}, "unitCode": "CMT"},{% endif %}
        "brand": {
            "@type": "Brand",
            "name": "{{ fsc.t('sawmill') }}"
        },
        "manufacturer": {
            "@type": "Organization",
            "name": "{{ fsc.t('sawmill') }}",
            "description": "{{ fsc.t('sawmill-desc') }}"
        },
        "category": "{{ (fsc.familyData ? fsc.familyData.descripcion : fsc.t('olive-wood')) | e('js') }}",
        "offers": {
            "@type": "Offer",
            "price": "{{ fsc.defaultVariant ? fsc.defaultVariant.price : fsc.product.price }}",
            "priceCurrency": "EUR",
            {% if fsc.calcConfig and fsc.calcConfig.mode == 'area' %}"unitCode": "MTK",
            "unitText": "m²",{% elseif fsc.calcConfig and fsc.calcConfig.mode == 'volume' %}"unitCode": "MTQ",
            "unitText": "m³",{% endif %}
            "availability": "{% if fsc.familyType == 'pieza_unica' and fsc.product.isSold %}https://schema.org/SoldOut{% elseif fsc.product.nostock %}https://schema.org/InStock{% elseif (fsc.defaultVariant ? fsc.defaultVariant.stock : fsc.product.stock) > 0 %}https://schema.org/InStock{% else %}https://schema.org/OutOfStock{% endif %}",
            "areaServed": [
                {"@type": "Country", "name": "Spain"},
                {"@type": "Country", "name": "France"},
                {"@type": "Country", "name": "Germany"},
                {"@type": "Place", "name": "European Union"}
            ],
            "shippingDetails": {
                "@type": "OfferShippingDetails",
                "shippingDestination": {
                    "@type": "DefinedRegion",
                    "name": "European Union"
                }
            }
        }
        {% if fsc.productVariants is not empty %},
        "hasVariant": [
            {% for variant in fsc.productVariants %}
            {
                "@type": "ProductModel",
                "name": "{{ variant.description | e('js') }}",
                "sku": "{{ variant.referencia }}",
                "offers": {
                    "@type": "Offer",
                    "price": "{{ variant.price }}",
                    "priceCurrency": "EUR"
                }
            }{% if not loop.last %},{% endif %}
            {% endfor %}
        ]
        {% endif %}
    }
    </script>

    <nav aria-label="breadcrumb" class="mb-3">
        <ol class="breadcrumb" itemscope itemtype="https://schema.org/BreadcrumbList">
            <li class="breadcrumb-item" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <a href="{{ asset('productos') }}" itemprop="item"><span itemprop="name">{{ fsc.t('products') }}</span></a>
                <meta itemprop="position" content="1">
            </li>
            <li class="breadcrumb-item active" aria-current="page" id="breadcrumb-product-name" itemprop="itemListElement" itemscope itemtype="https://schema.org/ListItem">
                <span itemprop="name">
                {% if fsc.defaultVariant and fsc.defaultVariant.description is not empty %}
                    {{ fsc.product.name }} – {{ fsc.defaultVariant.description }}
                {% else %}
                    {{ fsc.product.name }}
                {% endif %}
                </span>
                <meta itemprop="position" content="2">
            </li>
        </ol>
    </nav>

    {% if fsc.addedToCart == '1' %}
    <div class="alert alert-success d-flex justify-content-between align-items-center">
        <span><i class="fa-solid fa-circle-check"></i> {{ fsc.t('product-added-to-cart') }}</span>
        <a href="{{ asset('presupuesto') }}" class="btn btn-sm btn-success">
            <i class="fa-solid fa-file-invoice"></i> {{ fsc.t('view-presupuesto') }}
        </a>
    </div>
    {% elseif fsc.addedToCart == '0' %}
    <div class="alert alert-danger">
        <i class="fa-solid fa-triangle-exclamation"></i> {{ fsc.t('invalid-dimensions') }}
    </div>
    {% endif %}

    <div class="row">
        {# Images column #}
        <div class="col-md-5 mb-4">
            {% if fsc.productImages is not empty %}
            <div id="productCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
                <div class="carousel-inner" id="carousel-inner">
                    {% for img in fsc.productImages %}
                    <div class="carousel-item {% if loop.first %}active{% endif %}" data-idvariante="{{ img.idvariante ?? '' }}">
                        <img src="{{ img.url }}" class="d-block w-100 rounded" alt="{{ img.alt }}"
                             {% if img.description is not empty %}longdesc="{{ img.description | e('html_attr') }}"{% endif %}
                             style="max-height: 400px; object-fit: contain; background:#f8f9fa; cursor: zoom-in;"
                             onclick="openLightbox(this.src, this.alt)">
                        {% if img.referencia is not empty %}
                        <h5 class="text-center mt-2 mb-0">{{ img.referencia }}</h5>
                        {% endif %}
                        {% if img.description is not empty %}
                        <p class="text-center text-muted small mb-0">{{ img.description }}</p>
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#productCarousel" data-bs-slide="prev" id="carousel-prev">
                    <span class="carousel-control-prev-icon"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#productCarousel" data-bs-slide="next" id="carousel-next">
                    <span class="carousel-control-next-icon"></span>
                </button>
            </div>
            {# Lightbox modal for full-size image viewing #}
            <div class="modal fade" id="imageLightbox" tabindex="-1" aria-label="{{ fsc.t('image') }}" aria-hidden="true">
                <div class="modal-dialog modal-fullscreen">
                    <div class="modal-content bg-dark bg-opacity-75" onclick="handleLightboxBackdropClick(event)">
                        <div class="modal-header border-0 position-absolute w-100" style="z-index:1;">
                            <button type="button" class="btn-close btn-close-white ms-auto" aria-label="{{ fsc.t('close') }}" onclick="closeLightbox()"></button>
                        </div>
                        <div class="modal-body d-flex align-items-center justify-content-center p-0">
                            <button type="button" class="lightbox-nav lightbox-prev" aria-label="{{ fsc.t('previous') }}" onclick="lightboxNavigate(-1)">
                                <i class="fa-solid fa-chevron-left fa-2x"></i>
                            </button>
                            <img id="lightboxImage" src="" alt="" class="lightbox-img">
                            <button type="button" class="lightbox-nav lightbox-next" aria-label="{{ fsc.t('next') }}" onclick="lightboxNavigate(1)">
                                <i class="fa-solid fa-chevron-right fa-2x"></i>
                            </button>
                        </div>
                    </div>
                </div>
            </div>
            {% else %}
            <div class="bg-light d-flex align-items-center justify-content-center rounded mb-3" id="no-image-placeholder" style="height: 300px;">
                <i class="fa-solid fa-image fa-5x text-muted"></i>
            </div>
            {% endif %}
        </div>

        {# Product info column #}
        <div class="col-md-7 mb-4">
            <h1 class="h2 mb-2" id="product-title">
                {% if fsc.defaultVariant and fsc.defaultVariant.description is not empty %}
                    {{ fsc.product.name }} – {{ fsc.defaultVariant.description }}
                {% else %}
                    {{ fsc.product.name }}
                {% endif %}
            </h1>

            {% set currentPrice = fsc.defaultVariant ? fsc.defaultVariant.price : fsc.product.price %}
            {% set currentStock = fsc.defaultVariant ? fsc.defaultVariant.stock : fsc.product.stock %}
            <div class="d-flex align-items-center gap-3 mb-3">
                <span id="variant-price" class="mb-0">
                    {{ fsc.formatMoney(currentPrice) }}
                    {% if fsc.calcConfig and fsc.calcConfig.mode != 'none' and fsc.calcConfig.show_unit_price %}
                    <small class="text-muted">/{{ fsc.calcConfig.price_unit }}</small>
                    {% endif %}
                </span>
                {% if fsc.familyType == 'pieza_unica' and fsc.product.isSold %}
                <span id="variant-stock-badge" class="badge bg-warning text-dark fs-6">{{ fsc.t('sold') }}</span>
                {% elseif fsc.product.nostock %}
                <span id="variant-stock-badge"></span>
                {% elseif currentStock > 0 %}
                <span id="variant-stock-badge" class="badge bg-success fs-6">{{ fsc.t('in-stock') }}</span>
                {% else %}
                <span id="variant-stock-badge" class="badge bg-danger fs-6">{{ fsc.t('out-of-stock') }}</span>
                {% endif %}
            </div>

            {% if fsc.product.description is not empty %}
            <div class="mb-4">
                <h5>{{ fsc.t('description') }}</h5>
                <p class="text-muted">{{ fsc.product.description | nl2br }}</p>
            </div>
            {% endif %}

            {# Tablones: Show product dimensions (non-editable) #}
            {% if fsc.product.largo is not null or fsc.product.ancho is not null or fsc.product.espesor is not null %}
            <div class="mb-3" id="tablones-dimensions">
                <h6>{{ fsc.t('dimensions') }}</h6>
                {% if fsc.product.largo is not null or fsc.product.ancho is not null or fsc.product.espesor is not null %}
                <table class="table table-sm table-bordered" style="max-width: 300px;" id="dimensions-table">
                    {% if fsc.product.largo is not null %}
                    <tr><td class="fw-semibold">{{ fsc.t('largo') }}</td><td>{{ fsc.product.largo }}</td></tr>
                    {% endif %}
                    {% if fsc.product.ancho is not null %}
                    <tr><td class="fw-semibold">{{ fsc.t('ancho') }}</td><td>{{ fsc.product.ancho }}</td></tr>
                    {% endif %}
                    {% if fsc.product.espesor is not null %}
                    <tr><td class="fw-semibold">{{ fsc.t('espesor') }}</td><td>{{ fsc.product.espesor }}</td></tr>
                    {% endif %}
                </table>
                {% endif %}
            </div>
            {% endif %}

            {# Attribute-based variant selectors #}
            {% if fsc.productAttributes is not empty %}
            <div class="mb-4" id="attribute-selectors">
                {% for codatributo, attr in fsc.productAttributes %}
                <div class="mb-2">
                    <label class="form-label fw-semibold">{{ attr.nombre }}</label>
                    <select class="form-select attr-selector" data-codatributo="{{ codatributo }}" onchange="updateVariantFromAttributes()">
                        {% for idVal, valor in attr.values %}
                        <option value="{{ idVal }}"
                            {% if fsc.defaultVariant and fsc.defaultVariant.attributes[codatributo] == idVal %}selected{% endif %}>
                            {{ valor }}
                        </option>
                        {% endfor %}
                    </select>
                </div>
                {% endfor %}
            </div>
            {% elseif fsc.productVariants is not empty %}
            {# Fallback: simple dropdown when variants have no attribute data #}
            <div class="mb-4">
                <h5>{{ fsc.t('variants') }}</h5>
                <select id="variant-selector" class="form-select" onchange="updateVariant(this)">
                    {% for variant in fsc.productVariants %}
                    <option value="{{ variant.referencia }}" data-price="{{ variant.price }}" data-stock="{{ variant.stock }}"
                        data-idvariante="{{ variant.idvariante ?? '' }}"
                        data-description="{{ variant.description }}"
                        data-largo="{{ variant.largo ?? '' }}"
                        data-ancho="{{ variant.ancho ?? '' }}"
                        data-espesor="{{ variant.espesor ?? '' }}"
                        {% if fsc.defaultVariant and fsc.defaultVariant.referencia == variant.referencia %}selected{% endif %}>
                        {{ variant.description }} – {{ fsc.formatMoney(variant.price) }}
                    </option>
                    {% endfor %}
                </select>
            </div>
            {% endif %}

            {# === ARTESANÍA / TABLONES: sold overlay === #}
            {% if fsc.familyType == 'pieza_unica' and fsc.product.isSold %}
            <div class="alert alert-warning">
                <i class="fa-solid fa-tag"></i> {{ fsc.t('sold') }}
            </div>

            {# === Measurement calculator (area L×W / volume L×W×H): custom dimension input === #}
            {% elseif fsc.calcConfig and fsc.calcConfig.mode != 'none' %}
            {% set showForm = fsc.product.nostock or fsc.product.stock > 0 %}
            {% if showForm %}
            <form method="post" action="{{ asset('producto') }}?url={{ fsc.product.slug }}" id="tableros-form">
                <input type="hidden" name="action" value="add-to-cart">
                <input type="hidden" name="product_referencia" id="add-referencia"
                    value="{{ fsc.defaultVariant ? fsc.defaultVariant.referencia : fsc.product.referencia }}">
                <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">

                <h5>{{ fsc.t('enter-dimensions') }}</h5>
                {% if fsc.familyData %}
                <p class="text-muted small">
                    {% if fsc.familyData.largo_min > 0 or fsc.familyData.largo_max > 0 %}
                    {{ fsc.calcConfig.dims.length.label ?: fsc.t('largo') }}: {{ fsc.familyData.largo_min }} - {{ fsc.familyData.largo_max }} cm<br>
                    {% endif %}
                    {% if fsc.familyData.ancho_min > 0 or fsc.familyData.ancho_max > 0 %}
                    {{ fsc.calcConfig.dims.width.label ?: fsc.t('ancho') }}: {{ fsc.familyData.ancho_min }} - {{ fsc.familyData.ancho_max }} cm
                    {% endif %}
                </p>
                {% endif %}

                {% set dimInputs = [
                    {cfg: fsc.calcConfig.dims.length, id: 'largo_cm', fallback: fsc.t('largo')},
                    {cfg: fsc.calcConfig.dims.width, id: 'ancho_cm', fallback: fsc.t('ancho')}
                ] %}
                {% if fsc.calcConfig.mode == 'volume' %}
                    {% set dimInputs = dimInputs | merge([{cfg: fsc.calcConfig.dims.height, id: 'alto_cm', fallback: fsc.t('alto')}]) %}
                {% endif %}

                <div class="row g-2 mb-3">
                    {% for dim in dimInputs %}
                    <div class="col-auto">
                        <label class="form-label" for="{{ dim.id }}">
                            {{ dim.cfg.label ?: dim.fallback }} ({{ dim.cfg.unit }})
                        </label>
                        {% if dim.cfg.options is not empty %}
                        <select id="{{ dim.id }}" name="{{ dim.id }}" class="form-select" required
                                onchange="calculateTablerosPrice()">
                            <option value="">—</option>
                            {% for value in dim.cfg.options %}
                            <option value="{{ value }}">{{ value }}</option>
                            {% endfor %}
                        </select>
                        {% else %}
                        <input type="number" id="{{ dim.id }}" name="{{ dim.id }}" class="form-control" step="0.01"
                            min="{{ dim.cfg.min > 0 ? dim.cfg.min : '0.01' }}"
                            {% if dim.cfg.max > 0 %}max="{{ dim.cfg.max }}"{% endif %}
                            required oninput="calculateTablerosPrice()">
                        {% endif %}
                    </div>
                    {% endfor %}
                </div>

                <div class="mb-3" id="tableros-calc" style="display:none;">
                    {% if fsc.calcConfig.mode == 'volume' %}
                    <p class="mb-1"><strong>{{ fsc.t('volume') }}:</strong> <span id="tableros-area">0</span> m³</p>
                    {% else %}
                    <p class="mb-1"><strong>{{ fsc.t('area') }}:</strong> <span id="tableros-area">0</span> m²</p>
                    {% endif %}
                    <p class="mb-1"><strong>{{ fsc.t('calculated-price') }}:</strong> <span id="tableros-total-price">0,00 €</span></p>
                    {% if fsc.calcConfig.calc_weight and fsc.product.peso %}
                    <p class="mb-1"><strong>{{ fsc.t('capture-weight') }}:</strong> <span id="tableros-weight">0</span> kg</p>
                    {% endif %}
                </div>

                <button type="submit" id="add-to-cart-btn" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-cart-plus"></i> {{ fsc.t('add-to-presupuesto') }}
                </button>
            </form>
            {% else %}
            <button class="btn btn-secondary btn-lg" disabled>
                <i class="fa-solid fa-ban"></i> {{ fsc.t('out-of-stock') }}
            </button>
            {% endif %}

            {# === TABLONES: unique slab, quantity always 1 === #}
            {% elseif fsc.familyType == 'pieza_unica' %}
            {% set showForm = fsc.product.stock > 0 or fsc.product.nostock %}
            {% if showForm %}
            <form method="post" action="{{ asset('producto') }}?url={{ fsc.product.slug }}">
                <input type="hidden" name="action" value="add-to-cart">
                <input type="hidden" name="product_referencia" id="add-referencia"
                    value="{{ fsc.defaultVariant ? fsc.defaultVariant.referencia : fsc.product.referencia }}">
                <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">
                <input type="hidden" name="quantity" value="1">

                <button type="submit" id="add-to-cart-btn" class="btn btn-primary btn-lg">
                    <i class="fa-solid fa-cart-plus"></i> {{ fsc.t('add-to-presupuesto') }}
                </button>
            </form>
            {% else %}
            <button class="btn btn-secondary btn-lg" disabled>
                <i class="fa-solid fa-ban"></i> {{ fsc.t('out-of-stock') }}
            </button>
            {% endif %}

            {# === NORMAL / MERCANCÍA: standard add to cart === #}
            {% else %}
            {% set showForm = fsc.productVariants is not empty or fsc.product.stock > 0 or fsc.product.nostock %}
            {% if showForm %}
            <form method="post" action="{{ asset('producto') }}?url={{ fsc.product.slug }}">
                <input type="hidden" name="action" value="add-to-cart">
                <input type="hidden" name="product_referencia" id="add-referencia"
                    value="{{ fsc.defaultVariant ? fsc.defaultVariant.referencia : fsc.product.referencia }}">
                <input type="hidden" name="multireqtoken" value="{{ fsc.multiRequestProtection.newToken() }}">

                {% if fsc.familyType != 'pieza_unica' %}
                <div class="input-group mb-3" style="max-width: 200px;">
                    <label class="input-group-text" for="qty">{{ fsc.t('quantity') }}</label>
                    <input type="number" id="qty" name="quantity" value="1" min="1" {% if fsc.product.nostock %}max="999"{% else %}max="{{ currentStock }}"{% endif %} class="form-control">
                </div>
                {% else %}
                <input type="hidden" name="quantity" value="1">
                {% endif %}

                <button type="submit" id="add-to-cart-btn" class="btn btn-primary btn-lg"
                    {% if not fsc.product.nostock and currentStock <= 0 %}disabled{% endif %}>
                    <i class="fa-solid fa-cart-plus"></i> {{ fsc.t('add-to-presupuesto') }}
                </button>
            </form>
            {% else %}
            <button class="btn btn-secondary btn-lg" disabled>
                <i class="fa-solid fa-ban"></i> {{ fsc.t('out-of-stock') }}
            </button>
            {% endif %}
            {% endif %}
        </div>
    </div>

    {% else %}
    <div class="alert alert-warning">
        <i class="fa-solid fa-exclamation-triangle"></i> {{ fsc.t('product-not-found') }}
    </div>
    <a href="{{ asset('productos') }}" class="btn btn-primary">
        <i class="fa-solid fa-arrow-left"></i> {{ fsc.t('products') }}
    </a>
    {% endif %}

    {% if fsc.cartItemCount > 0 %}
    <div class="sticky-cart-btn me-3 text-end d-none d-md-block">
        <a href="{{ asset('presupuesto') }}" class="btn btn-success shadow">
            <i class="fa-solid fa-file-invoice"></i>
            {{ fsc.t('view-presupuesto') }} ({{ fsc.cartItemCount }})
        </a>
    </div>
    {% endif %}
</div>

<script>
var variantData = {{ fsc.productVariants | json_encode | raw }};
var variantImages = {{ fsc.variantImages | json_encode | raw }};
var allImages = {{ fsc.productImages | json_encode | raw }};
var productBaseName = {{ fsc.product.name | json_encode | raw }};
var inStockLabel = {{ fsc.t('in-stock') | json_encode | raw }};
var outOfStockLabel = {{ fsc.t('out-of-stock') | json_encode | raw }};
var soldLabel = {{ fsc.t('sold') | json_encode | raw }};
var familyType = {{ fsc.familyType | json_encode | raw }};
var calcMode = "{{ fsc.calcConfig ? fsc.calcConfig.mode : 'none' }}";
var hasCalc = calcMode !== 'none';
var calcOverage = {{ fsc.calcConfig ? fsc.calcConfig.overage_pct : 0 }};
var calcUnit = {{ fsc.calcConfig ? (fsc.calcConfig.price_unit | json_encode | raw) : '"m²"' }};
var calcShowUnit = {{ fsc.calcConfig and fsc.calcConfig.show_unit_price ? 'true' : 'false' }};
var productWeight = {{ fsc.product and fsc.product.peso ? fsc.product.peso : 0 }};

function formatMoney(amount) {
    return amount.toFixed(2).replace('.', ',') + ' \u20ac';
}

function updateCarouselForVariant(idvariante) {
    var inner = document.getElementById('carousel-inner');
    if (!inner) return;

    var items = inner.querySelectorAll('.carousel-item');
    var idvarianteStr = idvariante !== null && idvariante !== undefined ? String(idvariante) : '';
    var hasVariantImages = idvarianteStr !== '' && variantImages[idvariante] && variantImages[idvariante].length > 0;

    var visibleCount = 0;
    items.forEach(function (item) {
        var itemVariante = item.dataset.idvariante;
        var show;
        if (hasVariantImages) {
            show = itemVariante === idvarianteStr;
        } else {
            // No variant-specific images: show all images
            show = true;
        }
        item.style.display = show ? '' : 'none';
        if (show) visibleCount++;
    });

    // Ensure one item is active
    var activeFound = false;
    items.forEach(function (item) {
        if (item.style.display !== 'none') {
            if (!activeFound) {
                item.classList.add('active');
                activeFound = true;
            } else {
                item.classList.remove('active');
            }
        } else {
            item.classList.remove('active');
        }
    });

    // Show/hide prev/next buttons
    var prevBtn = document.getElementById('carousel-prev');
    var nextBtn = document.getElementById('carousel-next');
    if (prevBtn) prevBtn.style.display = visibleCount > 1 ? '' : 'none';
    if (nextBtn) nextBtn.style.display = visibleCount > 1 ? '' : 'none';

}

function updateProductTitle(description) {
    var title = document.getElementById('product-title');
    var breadcrumb = document.getElementById('breadcrumb-product-name');
    var fullName = description ? productBaseName + ' \u2013 ' + description : productBaseName;
    if (title) title.textContent = fullName;
    if (breadcrumb) breadcrumb.textContent = fullName;
}

function updateDimensionsTable(variant) {
    // No-op: tablones dimensions are displayed directly from the product, not the variant.
}

function updateVariantFromAttributes() {
    var selected = {};
    document.querySelectorAll('.attr-selector').forEach(function (sel) {
        selected[sel.dataset.codatributo] = parseInt(sel.value, 10);
    });

    var match = null;
    for (var i = 0; i < variantData.length; i++) {
        var v = variantData[i];
        var allMatch = true;
        for (var cod in selected) {
            if (!v.attributes || v.attributes[cod] !== selected[cod]) {
                allMatch = false;
                break;
            }
        }
        if (allMatch) {
            match = v;
            break;
        }
    }

    if (match) {
        var refInput = document.getElementById('add-referencia');
        if (refInput) refInput.value = match.referencia;

        var priceEl = document.getElementById('variant-price');
        if (priceEl) {
            priceEl.textContent = formatMoney(parseFloat(match.price));
            if (hasCalc && calcShowUnit) priceEl.innerHTML += ' <small class="text-muted">/' + calcUnit + '</small>';
        }

        var inStock = parseFloat(match.stock) > 0;
        var badge = document.getElementById('variant-stock-badge');
        if (badge) {
            if (hasCalc) {
                // Tableros: stock not controlled, no badge
                badge.className = '';
                badge.textContent = '';
            } else if (familyType === 'pieza_unica' && !inStock) {
                badge.className = 'badge bg-warning text-dark fs-6';
                badge.textContent = soldLabel;
            } else {
                badge.className = inStock ? 'badge bg-success fs-6' : 'badge bg-danger fs-6';
                badge.textContent = inStock ? inStockLabel : outOfStockLabel;
            }
        }

        var addBtn = document.getElementById('add-to-cart-btn');
        if (addBtn) {
            if (hasCalc) {
                addBtn.disabled = false;
            } else if (familyType === 'pieza_unica' && !inStock) {
                addBtn.disabled = true;
            } else {
                addBtn.disabled = !inStock;
            }
        }

        var qtyInput = document.getElementById('qty');
        if (qtyInput && inStock) qtyInput.max = Math.floor(match.stock);

        updateProductTitle(match.description);
        updateCarouselForVariant(match.idvariante);
        updateDimensionsTable(match);

        // Recalculate Tableros price if applicable
        if (hasCalc) calculateTablerosPrice();
    }
}

function updateVariant(select) {
    var option = select.options[select.selectedIndex];
    var refInput = document.getElementById('add-referencia');
    if (refInput) refInput.value = option.value;

    var price = parseFloat(option.dataset.price);
    var priceEl = document.getElementById('variant-price');
    if (priceEl) {
        priceEl.textContent = formatMoney(price);
        if (hasCalc && calcShowUnit) priceEl.innerHTML += ' <small class="text-muted">/' + calcUnit + '</small>';
    }

    var stock = parseFloat(option.dataset.stock);
    var inStock = stock > 0;
    var badge = document.getElementById('variant-stock-badge');
    if (badge) {
        if (hasCalc) {
            // Tableros: stock not controlled, no badge
            badge.className = '';
            badge.textContent = '';
        } else if (familyType === 'pieza_unica' && !inStock) {
            badge.className = 'badge bg-warning text-dark fs-6';
            badge.textContent = soldLabel;
        } else {
            badge.className = inStock ? 'badge bg-success fs-6' : 'badge bg-danger fs-6';
            badge.textContent = inStock ? inStockLabel : outOfStockLabel;
        }
    }

    var addBtn = document.getElementById('add-to-cart-btn');
    if (addBtn) {
        if (hasCalc) {
            addBtn.disabled = false;
        } else if (familyType === 'pieza_unica' && !inStock) {
            addBtn.disabled = true;
        } else {
            addBtn.disabled = !inStock;
        }
    }

    var qtyInput = document.getElementById('qty');
    if (qtyInput && inStock) qtyInput.max = Math.floor(stock);

    updateProductTitle(option.dataset.description || '');
    updateCarouselForVariant(option.dataset.idvariante || null);

    // Update Tablones dimensions from data attributes
    if (familyType === 'pieza_unica') {
        var variant = {
            largo: option.dataset.largo !== '' ? option.dataset.largo : null,
            ancho: option.dataset.ancho !== '' ? option.dataset.ancho : null,
            espesor: option.dataset.espesor !== '' ? option.dataset.espesor : null
        };
        updateDimensionsTable(variant);
    }

    // Recalculate Tableros price if applicable
    if (hasCalc) calculateTablerosPrice();
}

function calculateTablerosPrice() {
    var largoInput = document.getElementById('largo_cm');
    var anchoInput = document.getElementById('ancho_cm');
    var altoInput = document.getElementById('alto_cm');
    var calcDiv = document.getElementById('tableros-calc');
    var areaSpan = document.getElementById('tableros-area');
    var totalSpan = document.getElementById('tableros-total-price');
    var weightSpan = document.getElementById('tableros-weight');

    if (!largoInput || !anchoInput) return;

    var largo = parseFloat(largoInput.value) || 0;
    var ancho = parseFloat(anchoInput.value) || 0;
    var alto = altoInput ? (parseFloat(altoInput.value) || 0) : 0;

    var complete = largo > 0 && ancho > 0 && (calcMode !== 'volume' || alto > 0);
    if (complete) {
        // measure: m² for area mode, litres for volume mode (+ overage)
        var measure = (calcMode === 'volume')
            ? largo * ancho * alto / 1000000
            : largo * ancho / 10000;
        measure = measure * (1 + calcOverage / 100);

        // Current per-unit price (variant, falling back to the shown price)
        var unitPrice = 0;
        var refInput = document.getElementById('add-referencia');
        if (refInput) {
            for (var i = 0; i < variantData.length; i++) {
                if (variantData[i].referencia === refInput.value) {
                    unitPrice = parseFloat(variantData[i].price);
                    break;
                }
            }
        }
        if (unitPrice === 0) {
            var priceEl = document.getElementById('variant-price');
            if (priceEl) {
                var priceText = priceEl.textContent.replace(/[^\d,.-]/g, '').replace(',', '.');
                unitPrice = parseFloat(priceText) || 0;
            }
        }

        if (areaSpan) areaSpan.textContent = measure.toFixed(4);
        if (totalSpan) totalSpan.textContent = formatMoney(unitPrice * measure);
        if (weightSpan) weightSpan.textContent = (productWeight * measure).toFixed(1);
        if (calcDiv) calcDiv.style.display = '';
    } else {
        if (calcDiv) calcDiv.style.display = 'none';
    }
}

function scrollCarouselTo(index) {
    var inner = document.getElementById('carousel-inner');
    if (!inner) return;
    var visibleItems = Array.from(inner.querySelectorAll('.carousel-item')).filter(function(el) {
        return el.style.display !== 'none';
    });
    if (index < visibleItems.length) {
        visibleItems.forEach(function(el) { el.classList.remove('active'); });
        visibleItems[index].classList.add('active');
        visibleItems[index].scrollIntoView({behavior: 'smooth', block: 'nearest'});
    }
}

// On page load all images are shown (server-side rendering already initialises
// price, stock, title and referencia correctly for the default variant).
// Images are filtered only when the user explicitly selects a variant.

/* ── Lightbox (fullscreen image viewer) ─────────────────────── */
var lightboxModal = null;
var lightboxCurrentSrc = '';

function getVisibleImages() {
    var inner = document.getElementById('carousel-inner');
    if (!inner) return [];
    return Array.from(inner.querySelectorAll('.carousel-item')).filter(function(el) {
        return el.style.display !== 'none';
    }).map(function(el) {
        var img = el.querySelector('img');
        return img ? {src: img.src, alt: img.alt} : null;
    }).filter(Boolean);
}

function openLightbox(src, alt) {
    var imgEl = document.getElementById('lightboxImage');
    if (!imgEl) return;
    imgEl.src = src;
    imgEl.alt = alt || '';
    lightboxCurrentSrc = src;
    var images = getVisibleImages();
    var prev = document.querySelector('.lightbox-prev');
    var next = document.querySelector('.lightbox-next');
    if (prev) prev.style.display = images.length > 1 ? '' : 'none';
    if (next) next.style.display = images.length > 1 ? '' : 'none';
    if (!lightboxModal) {
        lightboxModal = new bootstrap.Modal(document.getElementById('imageLightbox'), {keyboard: true});
    }
    lightboxModal.show();
}

function closeLightbox() {
    if (lightboxModal) lightboxModal.hide();
}

function handleLightboxBackdropClick(event) {
    if (event.target === event.currentTarget || event.target.classList.contains('modal-body')) {
        closeLightbox();
    }
}

function lightboxNavigate(direction) {
    var images = getVisibleImages();
    if (images.length < 2) return;
    var srcs = images.map(function(img) { return img.src; });
    var idx = srcs.indexOf(lightboxCurrentSrc);
    if (idx === -1) idx = 0;
    idx = (idx + direction + images.length) % images.length;
    var imgEl = document.getElementById('lightboxImage');
    if (imgEl) {
        imgEl.src = images[idx].src;
        imgEl.alt = images[idx].alt;
        lightboxCurrentSrc = images[idx].src;
    }
}

document.addEventListener('keydown', function(e) {
    var modal = document.getElementById('imageLightbox');
    if (!modal || !modal.classList.contains('show')) return;
    if (e.key === 'ArrowLeft') lightboxNavigate(-1);
    else if (e.key === 'ArrowRight') lightboxNavigate(1);
});
</script>
